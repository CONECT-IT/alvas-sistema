{
  "annotations": { "list": [] },
  "editable": true,
  "title": "ALVAS API - SLIs/SLOs",
  "uid": "alvas-slis",
  "tags": ["sre", "sli", "slo"],
  "timezone": "browser",
  "panels": [
    {
      "title": "Availability SLI (exitos / total)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_errors_total{job=\"alvas-api\"}[5m])) / sum(rate(http_requests_total{job=\"alvas-api\"}[5m])))",
          "legendFormat": "Availability"
        }
      ]
    },
    {
      "title": "Latency p99",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket{job=\"alvas-api\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Error Budget Consumido (%)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - (1 - sum(rate(http_errors_total{job=\"alvas-api\"}[5m])) / sum(rate(http_requests_total{job=\"alvas-api\"}[5m])))) / 0.001",
          "legendFormat": "Error Budget Consumido"
        }
      ]
    },
    {
      "title": "Requests por segundo",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"alvas-api\"}[5m])) by (code)",
          "legendFormat": "{{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Latencia (p50, p90, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket{job=\"alvas-api\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_ms_bucket{job=\"alvas-api\"}[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket{job=\"alvas-api\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "SLO: Disponibilidad 99.9%",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_errors_total{job=\"alvas-api\"}[5m])) / sum(rate(http_requests_total{job=\"alvas-api\"}[5m])))",
          "legendFormat": "Availability SLI"
        },
        {
          "expr": "0.999",
          "legendFormat": "SLO 99.9%"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.99,
          "max": 1
        }
      }
    },
    {
      "title": "Error Budget Burn Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total{job=\"alvas-api\"}[5m])) / sum(rate(http_requests_total{job=\"alvas-api\"}[5m])) / (1 - 0.999)",
          "legendFormat": "Burn Rate"
        },
        {
          "expr": "1",
          "legendFormat": "Umbral (1x)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "schemaVersion": 39
}
