{
  "name": "@alvas/api",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "test:security": "bun test test/security/",
    "test:benchmark:k6": "k6 run test/benchmark/k6/api-smoke.js",
    "test:contract": "bun test test/contract/",
    "test:bdd": "cross-env NODE_OPTIONS=\"--import tsx\" cucumber-js \"test/bdd/features/**/*.feature\" --import \"test/bdd/features/**/*.ts\"",
    "build": "echo 'No build step needed for Wrangler'",
    "seed:generate": "bun ../../scripts/generate-seed-sql.mjs",
    "seed:local": "wrangler d1 execute alvas-dev --local --file src/seed.sql",
    "seed:staging": "wrangler d1 execute alvas-staging --remote --env staging --file src/seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@cucumber/cucumber": "^12.8.3",
    "@types/bun": "latest",
    "@types/uuid": "^11.0.0",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  }
}
