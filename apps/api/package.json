{
  "name": "@alvas/api",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "test:security": "bun test test/security/",
    "test:benchmark:k6": "k6 run test/benchmark/k6/api-smoke.js",
    "test:contract": "bun test test/contract/",
    "test:bdd": "cross-env NODE_OPTIONS=\"--import tsx\" cucumber-js \"test/bdd/features/**/*.feature\" --import \"test/bdd/features/**/*.ts\"",
    "build": "echo 'No build step needed for Wrangler'",
    "seed:generate": "bun ../../scripts/generate-seed-sql.mjs",
    "seed:local": "wrangler d1 execute alvas-dev --local --file ../../database/seeds/seed.sql",
    "seed:staging": "wrangler d1 execute alvas-staging --remote --env staging --file ../../database/seeds/seed.sql",
    "seed:production": "wrangler d1 execute alvas-main --remote --env production --file ../../database/seeds/seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@cucumber/cucumber": "^12.8.3",
    "@eslint/js": "^10.0.1",
    "@types/bun": "1.3.14",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "k6-html-reporter": "^1.0.5",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "@stryker-mutator/core": "^9.6.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "1.4.0",
    "@scalar/hono-api-reference": "0.10.20",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.23",
    "uuid": "14.0.0",
    "zod": "4.4.3"
  }
}
